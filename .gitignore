# Build outputs
*.bin
*.lst
*.log
*.p
*.h

# Allow test art data
!test/*.bin

# Allow sprite art and DPLC data
!art/uncompressed/**/*.bin
!art/optimized/**/*.bin
!games/sonic4/data/dplc/*.bin
!games/sonic4/data/dplc/optimized/*.bin
!games/sonic4/data/mappings/*.bin
!art/palettes/*.bin

# Vendored salvador (ZX0 packer) — keep sources, ignore build artifacts
!tools/salvador/**/*.h
tools/salvador/obj/
tools/salvador/salvador
tools/bin/

# MCP config (machine-specific)
.mcp.json

# ctags symbol index (generated)
tags
*.s4lz
*.zx0
*.tf
__pycache__/
.worktrees/
games/sonic4/data/generated/

# Build tool caches (content-hash keyed)
tools/.cache/
*.wav

# Scratch VGM register captures (root-level only). Intentional reference
# captures live under docs/research/reference_captures/ and stay tracked.
/*.vgm
